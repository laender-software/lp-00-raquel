---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Dra. Raquel Cosso — Endocrinologista e Metabologista',
  description = 'Endocrinologista em Belo Horizonte com atendimento humanizado e personalizado. Tireoide, diabetes, obesidade, SOP, menopausa e mais. Agende sua consulta.',
  canonical = 'https://raquelcosso.com.br',
  ogImage = '/og-image.jpg',
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OG / Twitter -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Physician",
        "name": "Dra. Raquel Cosso",
        "medicalSpecialty": "Endocrinology",
        "description": "Endocrinologista e Metabologista em Belo Horizonte. Atendimento humanizado e personalizado.",
        "url": "https://raquelcosso.com.br",
        "telephone": "+553199972136",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. do Contorno, 8000 — Sala 1012",
          "addressLocality": "Belo Horizonte",
          "addressRegion": "MG",
          "addressCountry": "BR",
          "postalCode": "30110-012"
        }
      }
    </script>

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Scroll reveal + header + mobile menu -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Scroll reveal
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.12 });
        els.forEach(el => obs.observe(el));

        // Counter animation
        const counters = document.querySelectorAll('[data-counter]');
        const counterObs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (!e.isIntersecting) return;
            const el = e.target;
            const target = parseInt(el.getAttribute('data-counter') || '0');
            const prefix = el.getAttribute('data-prefix') || '';
            const suffix = el.getAttribute('data-suffix') || '';
            let current = 0;
            const step = Math.ceil(target / 40);
            const timer = setInterval(() => {
              current = Math.min(current + step, target);
              el.textContent = prefix + current + suffix;
              if (current >= target) clearInterval(timer);
            }, 30);
            counterObs.unobserve(el);
          });
        }, { threshold: 0.5 });
        counters.forEach(el => counterObs.observe(el));

        // Header scroll
        const header = document.querySelector('header');
        window.addEventListener('scroll', () => {
          header?.classList.toggle('scrolled', window.scrollY > 20);
        });

        // Mobile menu
        const btn = document.getElementById('menu-toggle');
        const nav = document.getElementById('mobile-nav');
        btn?.addEventListener('click', () => {
          const open = nav?.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', String(!open));
        });
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
