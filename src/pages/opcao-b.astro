---
// OPÇÃO B — Paleta clean/clínica. Cinza escuro neutro no texto, dourado só nos labels.
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Especialidades from '../components/Especialidades.astro';
import Dores from '../components/Dores.astro';
import Sobre from '../components/Sobre.astro';
import Depoimentos from '../components/Depoimentos.astro';
import FAQ from '../components/FAQ.astro';
import CTAFinal from '../components/CTAFinal.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Footer from '../components/Footer.astro';

const theme = `
  /* OPÇÃO B — Texto cinza escuro neutro, footer cinza chumbo elegante */
  body { color: #2D3748; }
  h1, h2, h3, h4 { color: #1A202C; }
  footer { background-color: #2D3748 !important; }
`;
---
<Layout title="Opção B — Dra. Raquel" themeOverride={theme}>
  <div style="position:fixed;top:0;left:0;right:0;z-index:9999;background:#2D3748;color:white;text-align:center;padding:6px;font-size:12px;font-family:sans-serif;">
    🎨 OPÇÃO B — Clean / Clínica (cinza escuro neutro) &nbsp;|&nbsp;
    <a href="/" style="color:#C9A84C">Original</a> &nbsp;|&nbsp;
    <a href="/opcao-a" style="color:#C9A84C">Opção A</a> &nbsp;|&nbsp;
    <a href="/opcao-c" style="color:#C9A84C">Opção C</a>
  </div>
  <div style="margin-top:28px;">
    <Header />
    <main>
      <Hero />
      <Especialidades />
      <Dores />
      <Sobre />
      <Depoimentos />
      <FAQ />
      <CTAFinal />
    </main>
    <WhatsAppButton />
    <Footer />
  </div>
</Layout>
