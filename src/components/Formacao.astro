---
import { Image } from 'astro:assets';
import formImg from '../assets/images/raquel-hospital-jaleco.jpeg';

const credenciais = [
  'Medicina — Faculdade de Ciências Médicas de MG',
  'Clínica Médica — Santa Casa de Belo Horizonte',
  'Endocrinologia e Metabologia — Santa Casa de BH',
  'Equipe de Endocrinologia — Hospital Madre Teresa',
  'Preceptora da Residência Médica — Hospital Madre Teresa',
];
---

<section class="relative overflow-hidden py-24 lg:py-32 bg-bg-dark text-white" id="formacao">
  <!-- Gold geometric pattern (subtle top border) -->
  <div class="absolute left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text (right on desktop) -->
      <div class="reveal order-2">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-accent-light mb-4">
          Formação
        </p>

        <h2 class="font-serif text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.02em] text-bg-warm mb-8">
          Dedicação à excelência em endocrinologia
        </h2>

        <ul class="space-y-4">
          {credenciais.map((cred, i) => (
            <li class="reveal flex items-start gap-3" style={`transition-delay: ${i * 80}ms`}>
              <span class="mt-1.5 w-2 h-2 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
              <span class="text-base leading-relaxed text-bg-warm/80">{cred}</span>
            </li>
          ))}
        </ul>

        <!-- Badges -->
        <div class="flex flex-wrap gap-3 mt-8">
          <span class="inline-block text-xs font-medium text-accent-light border border-accent/30 rounded-full px-4 py-2">
            CRM-MG 82239
          </span>
          <span class="inline-block text-xs font-medium text-accent-light border border-accent/30 rounded-full px-4 py-2">
            RQE 68237
          </span>
        </div>
      </div>

      <!-- Photo (left on desktop) -->
      <div class="order-1">
        <div class="relative photo-zoom rounded-2xl">
          <Image
            src={formImg}
            alt="Dra. Raquel Cosso com jaleco no Hospital Madre Teresa"
            width={800}
            format="webp"
            quality={92}
            class="photo-editorial rounded-2xl object-cover object-top w-full aspect-[3/4]
                   shadow-[0_8px_32px_rgba(0,0,0,0.3)]"
            loading="lazy"
            decoding="async"
          />
          <!-- Gold corner accent -->
          <div class="absolute -bottom-3 -right-3 w-20 h-20 border-r-2 border-b-2 border-accent/40 rounded-br-2xl" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>
