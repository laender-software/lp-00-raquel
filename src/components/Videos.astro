<section class="py-16 md:py-24 bg-sand/30" id="videos">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <p class="text-teal-deep font-bold text-lg uppercase tracking-[0.2em] mb-3">Conteúdo</p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brown">
        Vídeos
      </h2>
      <p class="text-brown-light text-lg mt-4 max-w-xl mx-auto">
        Acompanhe meu trabalho nas redes sociais
      </p>
    </div>

    <!-- Instagram embeds grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start reveal">

      <div class="flex justify-center">
        <blockquote
          class="instagram-media"
          data-instgrm-permalink="https://www.instagram.com/reel/DVWukIhD8tj/"
          data-instgrm-version="14"
          style="background:#FFF; border:0; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.1); margin:0; max-width:340px; width:100%; min-width:280px;"
        >
          <div style="padding:16px;">
            <a href="https://www.instagram.com/reel/DVWukIhD8tj/" target="_blank" rel="noopener noreferrer" style="color:#c9a96e; font-family:Arial,sans-serif; font-size:14px; text-decoration:none;">
              Ver vídeo no Instagram
            </a>
          </div>
        </blockquote>
      </div>

      <div class="flex justify-center">
        <blockquote
          class="instagram-media"
          data-instgrm-permalink="https://www.instagram.com/reel/C2VHJilOT-U/"
          data-instgrm-version="14"
          style="background:#FFF; border:0; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.1); margin:0; max-width:340px; width:100%; min-width:280px;"
        >
          <div style="padding:16px;">
            <a href="https://www.instagram.com/reel/C2VHJilOT-U/" target="_blank" rel="noopener noreferrer" style="color:#c9a96e; font-family:Arial,sans-serif; font-size:14px; text-decoration:none;">
              Ver vídeo no Instagram
            </a>
          </div>
        </blockquote>
      </div>

      <div class="flex justify-center">
        <blockquote
          class="instagram-media"
          data-instgrm-permalink="https://www.instagram.com/reel/CrHPAfhgRwo/"
          data-instgrm-version="14"
          style="background:#FFF; border:0; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.1); margin:0; max-width:340px; width:100%; min-width:280px;"
        >
          <div style="padding:16px;">
            <a href="https://www.instagram.com/reel/CrHPAfhgRwo/" target="_blank" rel="noopener noreferrer" style="color:#c9a96e; font-family:Arial,sans-serif; font-size:14px; text-decoration:none;">
              Ver vídeo no Instagram
            </a>
          </div>
        </blockquote>
      </div>

    </div>

    <!-- Instagram follow CTA -->
    <div class="text-center mt-10 reveal">
      <a
        href="https://www.instagram.com/nyresedim/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-glow border-2 border-teal-deep text-teal-deep px-8 py-4 rounded-full font-semibold hover:bg-teal-deep hover:text-white transition-all inline-flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-teal-deep focus:ring-offset-2"
        aria-label="Seguir Nyres Edim no Instagram"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
