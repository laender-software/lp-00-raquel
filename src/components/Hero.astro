---
---
<section class="pt-28 pb-16 md:pt-36 md:pb-24 bg-[#F8F6F2]">
  <div class="mx-auto px-6 max-w-6xl grid md:grid-cols-2 gap-12 items-center">
    <!-- Texto -->
    <div class="reveal">
      <p class="text-[#C9A84C] font-sans text-sm font-semibold uppercase tracking-widest mb-4">
        Endocrinologista · CRM/MG XXXXX
      </p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-[#1a1a1a] leading-tight mb-6">
        Cuidado hormonal com atenção <em class="text-[#1B4F72] not-italic">personalizada</em>
      </h1>
      <p class="text-[#6B7280] text-lg mb-8 leading-relaxed">
        Diagnóstico preciso e tratamento humanizado para quem busca qualidade de vida e equilíbrio hormonal.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contato"
           class="bg-[#1B4F72] text-white px-8 py-3.5 rounded-full font-semibold text-sm text-center hover:bg-[#154060] transition-colors btn-pulse focus:ring-2 focus:ring-[#1B4F72] focus:ring-offset-2"
           aria-label="Agendar consulta com Dra. Raquel">
          Agendar Consulta
        </a>
        <a href="#especialidades"
           class="border-2 border-[#1B4F72] text-[#1B4F72] px-8 py-3.5 rounded-full font-semibold text-sm text-center hover:bg-[#1B4F72] hover:text-white transition-colors focus:ring-2 focus:ring-[#1B4F72] focus:ring-offset-2">
          Ver Especialidades
        </a>
      </div>
    </div>

    <!-- Imagem placeholder -->
    <div class="reveal-right flex justify-center">
      <div class="w-full max-w-md aspect-[3/4] bg-[#D9E6F0] rounded-2xl flex items-center justify-center text-[#6B7280] font-sans text-sm">
        Foto Dra. Raquel
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="mx-auto px-6 max-w-6xl mt-16">
    <div class="bg-white rounded-2xl shadow-sm border border-[#E5E0D8] grid grid-cols-3 divide-x divide-[#E5E0D8]">
      <div class="flex flex-col items-center py-6 px-4 reveal-scale">
        <span class="font-serif text-3xl md:text-4xl font-semibold text-[#1B4F72]">
          <span data-counter="10" data-suffix="+">0+</span>
        </span>
        <span class="text-[#6B7280] text-xs md:text-sm mt-1 text-center">Anos de Experiência</span>
      </div>
      <div class="flex flex-col items-center py-6 px-4 reveal-scale">
        <span class="font-serif text-3xl md:text-4xl font-semibold text-[#1B4F72]">
          <span data-counter="500" data-suffix="+">0+</span>
        </span>
        <span class="text-[#6B7280] text-xs md:text-sm mt-1 text-center">Pacientes Atendidos</span>
      </div>
      <div class="flex flex-col items-center py-6 px-4 reveal-scale">
        <span class="font-serif text-3xl md:text-4xl font-semibold text-[#1B4F72]">
          <span data-counter="8">0</span>
        </span>
        <span class="text-[#6B7280] text-xs md:text-sm mt-1 text-center">Especialidades</span>
      </div>
    </div>
  </div>
</section>
