---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/raquel-portrait-standing.jpeg';
---

<section class="relative flex items-center overflow-hidden bg-bg" id="hero">
  <!-- Gold geometric accent (decorative) -->
  <div class="absolute top-20 left-8 w-48 h-48 opacity-[0.06] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="50" y="50" width="100" height="100" stroke="var(--color-accent)" stroke-width="1" transform="rotate(45 100 100)" />
      <rect x="65" y="65" width="70" height="70" stroke="var(--color-accent)" stroke-width="0.75" transform="rotate(45 100 100)" />
      <rect x="80" y="80" width="40" height="40" stroke="var(--color-accent)" stroke-width="0.5" transform="rotate(45 100 100)" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 w-full">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-8 items-center pt-28 pb-20 lg:pt-36 lg:pb-28">
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-5">
          Endocrinologia &amp; Metabologia
        </p>

        <h1 class="reveal font-serif text-[clamp(2.25rem,5vw,3.25rem)] font-semibold leading-[1.08] tracking-[-0.03em] text-text mb-5">
          Saúde, qualidade de vida e
          <em class="text-primary italic">transformação</em>
        </h1>

        <p class="reveal text-lg leading-relaxed text-muted max-w-xl mb-8">
          Acredito em um atendimento médico individualizado, acolhedor e pautado em evidências científicas.
        </p>

        <div class="reveal flex flex-wrap gap-4 items-center">
          <a
            href="#contato"
            class="inline-flex items-center px-7 py-3.5 rounded-full bg-primary text-white font-semibold
                   hover:bg-primary-dark focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2
                   active:scale-[0.97] transition-all duration-200 shadow-[0_4px_16px_rgba(155,79,70,0.25)]"
          >
            Agendar Consulta
          </a>

          <span class="text-sm text-muted">
            CRM-MG 82239 · RQE 68237
          </span>
        </div>
      </div>

      <!-- Photo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Soft background shape -->
          <div class="absolute -inset-4 bg-bg-warm rounded-[2rem] -z-10 rotate-2" aria-hidden="true"></div>

          <div class="photo-warm-container rounded-2xl w-[min(100%,400px)] lg:w-[440px]">
            <Image
              src={heroImg}
              alt="Dra. Raquel Cosso, endocrinologista, em foto profissional lifestyle"
              width={880}
              format="webp"
              quality={92}
              class="photo-warm rounded-2xl object-cover object-top w-full aspect-[3/4]
                     shadow-[0_8px_32px_rgba(30,25,21,0.1),0_2px_8px_rgba(30,25,21,0.06)]"
              loading="eager"
              decoding="async"
            />
          </div>

        </div>
      </div>
    </div>
  </div>

</section>
