---
---
<style>
  header { transition: box-shadow 0.3s ease, background 0.3s ease; }
  header.scrolled { box-shadow: 0 2px 20px rgba(27,79,114,0.10); }
</style>

<header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-[#E5E0D8]" id="main-header">
  <div class="mx-auto px-6 max-w-6xl flex items-center justify-between h-16 md:h-18">
    <!-- Logo -->
    <a href="#" class="font-serif text-xl font-semibold text-[#1B4F72] tracking-wide" aria-label="Página inicial">
      Dra. Raquel Cosso
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-sans" aria-label="Navegação principal">
      <a href="#especialidades" class="text-[#6B7280] hover:text-[#1B4F72] transition-colors">Especialidades</a>
      <a href="#sobre"          class="text-[#6B7280] hover:text-[#1B4F72] transition-colors">Sobre</a>
      <a href="#depoimentos"    class="text-[#6B7280] hover:text-[#1B4F72] transition-colors">Depoimentos</a>
      <a href="#faq"            class="text-[#6B7280] hover:text-[#1B4F72] transition-colors">FAQ</a>
      <a href="#contato"
         class="bg-[#1B4F72] text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-[#154060] transition-colors focus:ring-2 focus:ring-[#1B4F72] focus:ring-offset-2 btn-pulse"
         aria-label="Agendar consulta">
        Agendar Consulta
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" aria-label="Abrir menu" aria-expanded="false"
            class="md:hidden flex flex-col gap-1.5 p-2 focus:ring-2 focus:ring-[#1B4F72] rounded">
      <span class="block w-6 h-0.5 bg-[#1B4F72]"></span>
      <span class="block w-6 h-0.5 bg-[#1B4F72]"></span>
      <span class="block w-6 h-0.5 bg-[#1B4F72]"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="hidden md:hidden bg-white border-t border-[#E5E0D8] px-6 py-4 flex flex-col gap-4 text-sm font-sans">
    <a href="#especialidades" class="text-[#6B7280] hover:text-[#1B4F72]">Especialidades</a>
    <a href="#sobre"          class="text-[#6B7280] hover:text-[#1B4F72]">Sobre</a>
    <a href="#depoimentos"    class="text-[#6B7280] hover:text-[#1B4F72]">Depoimentos</a>
    <a href="#faq"            class="text-[#6B7280] hover:text-[#1B4F72]">FAQ</a>
    <a href="#contato"
       class="bg-[#1B4F72] text-white px-5 py-2.5 rounded-full text-sm font-semibold text-center hover:bg-[#154060] transition-colors">
      Agendar Consulta
    </a>
  </div>
</header>
