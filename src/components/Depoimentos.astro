---
const depoimentos = [
  {
    iniciais: 'M.S.',
    texto: 'A Dra. Raquel foi extremamente atenciosa. Finalmente entendi o que estava acontecendo com meu corpo após anos de tratamento sem resultado. Recomendo demais!',
    condicao: 'Paciente — Hipotireoidismo',
  },
  {
    iniciais: 'L.B.',
    texto: 'Depois de muita luta com o peso, a Dra. Raquel identificou um problema metabólico que nenhum outro médico tinha encontrado. Minha qualidade de vida mudou completamente.',
    condicao: 'Paciente — Obesidade e Resistência à Insulina',
  },
  {
    iniciais: 'P.R.',
    texto: 'Consulta humanizada, escuta atenta e explicações muito claras. Saí da consulta com um plano de tratamento que finalmente faz sentido pra mim.',
    condicao: 'Paciente — SOP',
  },
];
---
<section id="depoimentos" class="py-16 md:py-28 bg-[#F8F6F2]">
  <div class="mx-auto px-6 max-w-6xl">
    <div class="text-center mb-14 reveal">
      <p class="text-[#C9A84C] text-sm font-semibold uppercase tracking-widest mb-3">O que dizem os pacientes</p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-[#1a1a1a]">Depoimentos</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
      {depoimentos.map(({ iniciais, texto, condicao }) => (
        <div class="reveal bg-white border border-[#E5E0D8] rounded-2xl p-8 flex flex-col gap-5 card-lift">
          <!-- Estrelas -->
          <div class="flex gap-1" aria-label="5 estrelas">
            {[1,2,3,4,5].map(() => (
              <span class="text-[#C9A84C] text-lg" aria-hidden="true">★</span>
            ))}
          </div>
          <p class="text-[#1a1a1a] text-sm leading-relaxed flex-1">"{texto}"</p>
          <div>
            <p class="font-semibold text-[#1B4F72] text-sm">{iniciais}</p>
            <p class="text-[#6B7280] text-xs">{condicao}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
